{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:alpine": "node esbuild.config.mjs",
    "build:er": "vite build --mode library",
    "build:all": "npm run build:alpine && npm run build:er",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@tanstack/vue-query": "^5.100.11",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "alpinejs": "^3.14.3",
    "element-plus": "^2.14.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.8"
  }
}
