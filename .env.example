# MS Access MCP Server - Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is already in .gitignore — safe for secrets.
#
# Generate a secure API key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# =============================================================================
# REQUIRED
# =============================================================================

# API Key for Bearer token authentication.
# Must be at least 32 characters with high entropy (mixed case, digits, special chars).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_MCP_API_KEY=your-32-char-minimum-high-entropy-key-here

# =============================================================================
# NETWORK (optional - defaults shown)
# =============================================================================

# Bind address. Default: 127.0.0.1 (localhost only - secure)
# WARNING: Setting to 0.0.0.0 exposes the server to all network interfaces.
# Only change this if you have TLS configured and understand the security implications.
ACCESS_MCP_HOST=127.0.0.1

# Bind port. Default: 8000
ACCESS_MCP_PORT=8000

# =============================================================================
# SECURITY (optional)
# =============================================================================

# Semicolon-separated list of directories allowed for file operations.
# Paths outside these directories will be rejected.
# Default: user's home directory
ACCESS_MCP_ALLOWED_DIRS=C:\Users\YourName

# When true, requires Bearer token auth on MCP initialize handshake.
# Default: false (auth required only on tool calls)
# ACCESS_MCP_REQUIRE_AUTH_ON_INITIALIZE=false

# Path for structured audit logs (optional).
# When set, each tool call and auth event is appended to this file as JSON.
# ACCESS_MCP_AUDIT_LOG_PATH=C:\logs\mcp-audit.json

# =============================================================================
# FILE OPERATIONS (optional)
# =============================================================================

# When true, preserves Windows registry Trusted Locations before and restores
# after VBA-modifying operations. Only applies on Windows.
# Default: false
# ACCESS_MCP_PRESERVE_TRUSTED_LOCATIONS=false